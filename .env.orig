# general
DATADIR=/mnt/dockerData
SERVARRDIR=/servarrData/
TZ=America/Chicago
PUID=1000 # User
PUID_APPS=568 # App user (linuxserver.io containers)
PGID=1001 # Group; recommend making a group for docker users.

# AdGuard Home web UI password
AD_GUARD_PASSWORD=REPLACE_ME

# TeslaMate
TESLAMATE_DB_PASSWORD=REPLACE_ME
TESLAMATE_ENCRYPTION_KEY=REPLACE_ME

# Uptime monitoring (monitoring.yaml heartbeat-pusher)
# Comma-separated check_url|push_url pairs for internal services.
# Push tokens come from the fly.io Uptime Kuma UI (create Push-type monitors).
# Format: http://<swarm-service>:<port>|https://dlin-uptime-kuma.fly.dev/api/push/TOKEN,...
# Uses Docker Swarm native DNS (<stack>_<service>) to avoid circular dependency on AdGuard.
# Exceptions: qbt/sabnzb use .swarm.localdomain (TrueNAS apps, not on overlay).
# AdGuard uses keepalived VIP IPs directly (host-networked, not on overlay).
KUMA_MONITORS=http://media_sonarr:8989|https://dlin-uptime-kuma.fly.dev/api/push/GYdsTnlf9t,http://media_radarr:7878|https://dlin-uptime-kuma.fly.dev/api/push/AKbDexkwpL,http://media_readarr:8787|https://dlin-uptime-kuma.fly.dev/api/push/3lsk6Nr1Hn,http://media_bazarr:6767|https://dlin-uptime-kuma.fly.dev/api/push/uJrMGPV1w5,http://media_prowlarr:9696|https://dlin-uptime-kuma.fly.dev/api/push/qRT4ZmJeWx,http://media_mylar3:8090|https://dlin-uptime-kuma.fly.dev/api/push/PFNBg3p2hW,http://media_maintainerr:6246|https://dlin-uptime-kuma.fly.dev/api/push/GM3DEytnA7,http://qbt.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/bucxacRXFb,http://sabnzb.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/II16KcZZ95,http://teslamate_teslamate:4000|https://dlin-uptime-kuma.fly.dev/api/push/wW0orHCWKZ,http://192.168.0.253:3000|https://dlin-uptime-kuma.fly.dev/api/push/b43c136752e5dec8,http://192.168.0.254:3000|https://dlin-uptime-kuma.fly.dev/api/push/ee49497487ce50f9,http://tier1_nginx-proxy-manager:81|https://dlin-uptime-kuma.fly.dev/api/push/2956edbd6c2954ec,http://media_lidarr:8686|https://dlin-uptime-kuma.fly.dev/api/push/1de2adf0cfc2ac33

