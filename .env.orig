# general
DATADIR=/mnt/dockerData
SERVARRDIR=/servarrData/
TZ=America/Chicago
PUID=1000 # User
PUID_APPS=568 # App user (linuxserver.io containers)
PGID=1001 # Group; recommend making a group for docker users.

# AdGuard Home web UI password
AD_GUARD_PASSWORD=REPLACE_ME

# TeslaMate
TESLAMATE_DB_PASSWORD=REPLACE_ME
TESLAMATE_ENCRYPTION_KEY=REPLACE_ME

# Uptime monitoring (monitoring.yaml heartbeat-pusher)
# Comma-separated check_url|push_url pairs for internal services.
# Push tokens come from the fly.io Uptime Kuma UI (create Push-type monitors).
# Format: http://service.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/TOKEN,...
KUMA_MONITORS=http://sonarr.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/GYdsTnlf9t,http://radarr.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/AKbDexkwpL,http://readarr.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/3lsk6Nr1Hn,http://bazarr.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/uJrMGPV1w5,http://prowlarr.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/qRT4ZmJeWx,http://mylar3.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/PFNBg3p2hW,http://maintainerr.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/GM3DEytnA7,http://qbt.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/bucxacRXFb,http://sabnzb.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/II16KcZZ95,http://teslamate.swarm.localdomain|https://dlin-uptime-kuma.fly.dev/api/push/wW0orHCWKZ

